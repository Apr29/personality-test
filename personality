                title: "🫂 高敏感小天使",
                badge: "xFxJ · 高宜人 & 高神经质",
                desc: "<h3>『世界以痛吻我，我报之以歌』</h3><p class='tag'>但你先别吻，我疼</p><p>✨ <strong>特点分析</strong>：你是朋友圈里的“情绪感应器”，谁不开心你第一个知道。你善良、体贴，总是优先考虑别人的感受。但你也很容易内耗，会因为别人一句无心的话emo一整天。你的共情能力是你的天赋，也是你的软肋。</p><p>💧 <strong>青春痛点</strong>：讨好型人格预警！总是委屈自己成全别人。情绪像过山车，容易被人拿捏。</p><p>🌱 <strong>成长建议</strong>：亲爱的，你的善良必须带点锋芒。先爱自己，再爱别人。学会说“不”，你会发现，真正的朋友不会因为你拒绝而离开。<br>📍 <em>参考人格：ISFJ / INFJ</em></p>"
            },
            D: {
                title: "🐶 快乐修勾 / 社交悍匪",
                badge: "ExxP · 高外向 & 低尽责",
                desc: "<h3>『管他呢！先快乐再说！』</h3><p class='tag'>全宇宙都是我的游乐场</p><p>✨ <strong>特点分析</strong>：只要有你在，气氛永远不会尴尬！你是天生的社交达人，能量满满， spontaneity是你的代名词。你喜欢新鲜感，讨厌枯燥的计划和规则。你的朋友都超爱你，因为你就是快乐的源泉。</p><p>💧 <strong>青春痛点</strong>：三分钟热度，做事容易虎头蛇尾。有时候太嗨了，没注意到别人的情绪，或者不小心“嘴比脑子快”得罪人。</p><p>🌱 <strong>成长建议</strong>：你的快乐很有感染力，但也要学会承担责任。试着把一件事坚持做下去，哪怕只是每天给花浇水。偶尔收一收你的锋芒，你会发现安静的世界也很美。<br>📍 <em>参考人格：ESFP / ENFP</em></p>"
            },
            E: {   // 端水大师
                title: "⚖️ 端水大师 / 六边形战士",
                badge: "均衡型 · 可i可e",
                desc: "<h3>『人格界的米其林三星主厨』</h3><p class='tag'>把各种特质都调和得恰到好处</p><p>✨ <strong>特点分析</strong>：你既能在人群中狂欢，也能享受独处的宁静；既有冲劲，也能沉下心。你适应性极强，是传说中的“可i可e”。你没什么性格短板，是大家眼中情绪稳定、最好相处的那个人。</p><p>💧 <strong>青春痛点</strong>：可能偶尔会觉得迷茫，不知道自己到底“最”想要什么，有点随波逐流。</p><p>🌱 <strong>成长建议</strong>：你的中庸是你的优势，可以试着在某个你特别感兴趣的领域深挖一下，找到你独特的热情所在！</p>"
            }
        };

        // 核心数据
        const totalQ = questions.length;
        let answers = new Array(totalQ).fill(null);      // 存储每道题选的 A/B/C/D
        let currentIndex = 0;                            // 0-19

        // DOM 元素
        const quizSection = document.getElementById('quizSection');
        const resultSection = document.getElementById('resultSection');
        const questionCounter = document.getElementById('questionCounter');
        const progressFill = document.getElementById('progressFill');
        const questionText = document.getElementById('questionText');
        const optionsContainer = document.getElementById('optionsContainer');
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');
        const restartBtn = document.getElementById('restartBtn');
        const resultTypeTitle = document.getElementById('resultTypeTitle');
        const resultDescription = document.getElementById('resultDescription');
        const statisticDisplay = document.getElementById('statisticDisplay');

        // 更新界面: 渲染当前题目 (currentIndex)
        function renderQuestion() {
            const q = questions[currentIndex];
            questionText.innerText = q.text;
            // 生成选项html
            let htmlStr = '';
            for (let i = 0; i < q.options.length; i++) {
                const opt = q.options[i];
                const optLetter = opt[0]; // A, B, C, D
                const checked = (answers[currentIndex] === optLetter) ? 'checked' : '';
                htmlStr += `
                    <label class="option-item">
                        <input type="radio" name="questionOpt" value="${optLetter}" ${checked}>
                        <span class="option-text">${opt}</span>
                    </label>
                `;
            }
            optionsContainer.innerHTML = htmlStr;

            // 更新题号、进度条
            questionCounter.innerText = `第 ${currentIndex+1} / ${totalQ} 题`;
            const percent = ((currentIndex + 1) / totalQ) * 100;
            progressFill.style.width = percent + '%';

            // 处理上一题按钮禁用
            prevBtn.disabled = (currentIndex === 0);

            // 下一题按钮文字
            if (currentIndex === totalQ - 1) {
                nextBtn.innerText = '📋 查看结果 📋';
            } else {
                nextBtn.innerText = '下一题 ➡️';
            }
        }

        // 通过事件代理监听选项变化，更新answers
        optionsContainer.addEventListener('change', function(e) {
            if (e.target.name === 'questionOpt') {
                answers[currentIndex] = e.target.value;
            }
        });

        // 上一题
        prevBtn.addEventListener('click', function() {
            if (currentIndex > 0) {
                currentIndex--;
                renderQuestion();
            }
        });

        // 下一题 / 提交
        nextBtn.addEventListener('click', function() {
            // 检查当前题目有没有选中
            if (answers[currentIndex] === null) {
                alert('🌸 选一下嘛，不要害羞～ 这题得选才能继续～');
                return;
            }

            // 如果是最后一题 → 显示结果
            if (currentIndex === totalQ - 1) {
                // 确保所有题目都答了
                const missing = answers.findIndex(ans => ans === null);
                if (missing !== -1) {
                    alert(`还有第 ${missing+1} 题没选哟，回到前面答完才能生成报告～`);
                    // 跳转到缺失题
                    currentIndex = missing;
                    renderQuestion();
                    return;
                }
                // 计算并展示结果
                showResult();
            } else {
                // 不是最后一题，下一题
                currentIndex++;
                renderQuestion();
            }
        });

        // 重新测试
        restartBtn.addEventListener('click', function() {
            answers.fill(null);
            currentIndex = 0;
            renderQuestion();
            resultSection.style.display = 'none';
            quizSection.style.display = 'block';
        });

        // 统计函数：返回{ A: count, B: count, C: count, D: count }
        function countAnswers() {
            const counts = { A:0, B:0, C:0, D:0 };
            answers.forEach(ans => { if (ans) counts[ans]++; });
            return counts;
        }

        // 根据counts确定类型: 'A','B','C','D' 或 'E'(端水)
        function determineType(counts) {
            const values = [counts.A, counts.B, counts.C, counts.D];
            const maxVal = Math.max(...values);
            // 找出所有等于maxVal的选项
            const maxItems = [];
            if (counts.A === maxVal) maxItems.push('A');
            if (counts.B === maxVal) maxItems.push('B');
            if (counts.C === maxVal) maxItems.push('C');
            if (counts.D === maxVal) maxItems.push('D');

            if (maxItems.length === 1) {
                return maxItems[0];   // 唯一最多
            } else {
                return 'E';  // 端水大师
            }
        }

        // 显示结果页
        function showResult() {
            const counts = countAnswers();
            const typeKey = determineType(counts);
            const report = reportMap[typeKey];

            resultTypeTitle.innerText = report.title + ' ' + report.badge;
            resultDescription.innerHTML = report.desc;

            // 统计数据显示
            const total = totalQ;
            statisticDisplay.innerHTML = `
                <div>📊 你的选项分布</div>
                <div style="display:flex; justify-content:space-around; margin-top:15px; flex-wrap:wrap;">
                    <span style="background:#ffd4e6; padding:8px 16px; border-radius:40px;">🅰️ A: ${counts.A}</span>
                    <span style="background:#ffd4e6; padding:8px 16px; border-radius:40px;">🅱️ B: ${counts.B}</span>
                    <span style="background:#ffd4e6; padding:8px 16px; border-radius:40px;">🅲️ C: ${counts.C}</span>
                    <span style="background:#ffd4e6; padding:8px 16px; border-radius:40px;">🅳️ D: ${counts.D}</span>
                </div>
                <p style="margin-top:14px;">${typeKey === 'E' ? '🌟 雨露均沾 · 端水艺术家' : '🔮 你的主型如上，超准！'}</p>
            `;

            // 切换显示
            quizSection.style.display = 'none';
            resultSection.style.display = 'block';
        }

        // 初始化第一题
        renderQuestion();

        // 点击label也可以触发radio，但change事件已覆盖
    })();
</script>
